{
  "name": "solariview",
  "version": "0.2.1",
  "description": "On-chain clarity, local-first. Multi-chain portfolio aggregator for the sovereign developer.",
  "keywords": [
    "ethereum",
    "evm",
    "blockchain",
    "portfolio",
    "cli",
    "web3",
    "multichain",
    "nft",
    "defi",
    "privacy"
  ],
  "author": "SolariView",
  "license": "MIT",
  "homepage": "https://github.com/SolariView/SolariView#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SolariView/SolariView.git"
  },
  "bugs": {
    "url": "https://github.com/SolariView/SolariView/issues"
  },
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "solariview": "src/cli.js",
    "solariview-web": "web/server.js"
  },
  "files": [
    "src/abi.js",
    "src/chains.js",
    "src/cli.js",
    "src/index.js",
    "src/reader.js",
    "src/utils.js",
    "web/index.html",
    "web/server.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/cli.js",
    "dev:web": "node web/server.js",
    "test": "node --test src/chains.test.js src/utils.test.js src/reader.test.js src/cli.test.js web/server.test.js",
    "test:coverage": "c8 node --test src/chains.test.js src/utils.test.js src/reader.test.js src/cli.test.js web/server.test.js"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "dotenv": "^16.4.5"
  }
}
